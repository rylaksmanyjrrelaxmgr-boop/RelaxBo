async def banned_words_add_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """معالج إضافة كلمة محظورة إلى المجموعة"""
    query = update.callback_query
    if query:
        await query.answer()
    
    user_id = update.effective_user.id
    chat_id = int(query.data.split(":")[-1]) if query else context.user_data.get('banned_words_chat_id')
    
    if not chat_id:
        if query:
            await query.edit_message_text("❌ لم يتم تحديد المجموعة")
        return
    
    if not await is_authorized_in_group(context.bot, chat_id, user_id):
        if query:
            await query.answer(get_text(user_id, 'admin_only'), show_alert=True)
        else:
            await update.message.reply_text(get_text(user_id, 'admin_only'))
        return
    
    context.user_data['state'] = UserState.WAITING_GROUP_BANNED_WORD
    context.user_data['banned_words_chat_id'] = chat_id
    
    msg = "➕ **إضافة كلمة محظورة**\n\nأرسل الكلمة التي تريد إضافتها إلى قائمة الكلمات المحظورة:"
    
    if query:
        await safe_edit_markdown(query, msg)
    else:
        await update.message.reply_text(msg, parse_mode="MarkdownV2")

async def banned_words_list_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """معالج عرض الكلمات المحظورة في المجموعة"""
    query = update.callback_query
    if query:
        await query.answer()
    
    user_id = update.effective_user.id
    chat_id = int(query.data.split(":")[-1]) if query else context.user_data.get('banned_words_chat_id')
    
    if not chat_id:
        if query:
            await query.edit_message_text("❌ لم يتم تحديد المجموعة")
        return
    
    if not await is_authorized_in_group(context.bot, chat_id, user_id):
        if query:
            await query.answer(get_text(user_id, 'admin_only'), show_alert=True)
        else:
            await update.message.reply_text(get_text(user_id, 'admin_only'))
        return
    
    words = await db_get_banned_words(chat_id)
    
    if not words:
        text = "📭 **لا توجد كلمات محظورة في هذه المجموعة**"
        keyboard = InlineKeyboardMarkup([
            [InlineKeyboardButton("➕ إضافة كلمة", callback_data=f"{CallbackData.BANNED_WORDS_ADD_PREFIX}{chat_id}")],
            [InlineKeyboardButton("🔙 رجوع", callback_data=f"{CallbackData.SECURITY_BANNED_WORDS_MENU_PREFIX}{chat_id}")]
        ])
        if query:
            await safe_edit_markdown(query, text, reply_markup=keyboard)
        else:
            await safe_send_markdown(context.bot, user_id, text, reply_markup=keyboard)
        return
    
    text = "🚫 **الكلمات المحظورة في المجموعة**\n━━━━━━━━━━━━━━━━━━━━━━\n\n"
    
    for idx, (word, added_by, added_at) in enumerate(words[:30], 1):
        text += f"{idx}. `{word}`\n"
        if added_by:
            text += f"   👤 أضيف بواسطة: `{added_by}`\n"
        if added_at:
            try:
                dt = datetime.fromisoformat(added_at)
                dt_mecca = utc_to_mecca(dt)
                text += f"   📅 التاريخ: {dt_mecca.strftime('%Y-%m-%d')}\n"
            except:
                pass
        text += "\n"
    
    if len(words) > 30:
        text += f"\n... و {len(words) - 30} كلمة أخرى"
    
    keyboard = InlineKeyboardMarkup([
        [InlineKeyboardButton("➕ إضافة كلمة", callback_data=f"{CallbackData.BANNED_WORDS_ADD_PREFIX}{chat_id}"),
         InlineKeyboardButton("🗑️ حذف كلمة", callback_data=f"{CallbackData.BANNED_WORDS_REMOVE_PREFIX}{chat_id}")],
        [InlineKeyboardButton("🔙 رجوع", callback_data=f"{CallbackData.SECURITY_BANNED_WORDS_MENU_PREFIX}{chat_id}")]
    ])
    
    if query:
        await safe_edit_markdown(query, text, reply_markup=keyboard)
    else:
        await safe_send_markdown(context.bot, user_id, text, reply_markup=keyboard)

async def banned_words_remove_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """معالج حذف كلمة محظورة من المجموعة"""
    query = update.callback_query
    if query:
        await query.answer()
    
    user_id = update.effective_user.id
    chat_id = int(query.data.split(":")[-1]) if query else context.user_data.get('banned_words_chat_id')
    
    if not chat_id:
        if query:
            await query.edit_message_text("❌ لم يتم تحديد المجموعة")
        return
    
    if not await is_authorized_in_group(context.bot, chat_id, user_id):
        if query:
            await query.answer(get_text(user_id, 'admin_only'), show_alert=True)
        else:
            await update.message.reply_text(get_text(user_id, 'admin_only'))
        return
    
    context.user_data['state'] = UserState.WAITING_REMOVE_GROUP_BANNED_WORD
    context.user_data['banned_words_chat_id'] = chat_id
    
    words = await db_get_banned_words(chat_id)
    
    if not words:
        text = "📭 **لا توجد كلمات محظورة لحذفها**"
        keyboard = InlineKeyboardMarkup([
            [InlineKeyboardButton("➕ إضافة كلمة", callback_data=f"{CallbackData.BANNED_WORDS_ADD_PREFIX}{chat_id}")],
            [InlineKeyboardButton("🔙 رجوع", callback_data=f"{CallbackData.SECURITY_BANNED_WORDS_MENU_PREFIX}{chat_id}")]
        ])
        if query:
            await safe_edit_markdown(query, text, reply_markup=keyboard)
        else:
            await safe_send_markdown(context.bot, user_id, text, reply_markup=keyboard)
        return
    
    text = "🗑️ **اختر الكلمة لحذفها**\n━━━━━━━━━━━━━━━━━━━━━━\n\n"
    keyboard = []
    
    for word, added_by, added_at in words[:20]:
        text += f"• `{word}`\n"
        keyboard.append([InlineKeyboardButton(f"🗑️ حذف {word}", callback_data=f"delete_banned_word:{chat_id}:{word}")])
    
    if len(words) > 20:
        text += f"\n... و {len(words) - 20} كلمة أخرى"
    
    keyboard.append([InlineKeyboardButton("🔙 رجوع", callback_data=f"{CallbackData.SECURITY_BANNED_WORDS_MENU_PREFIX}{chat_id}")])
    
    if query:
        await safe_edit_markdown(query, text, reply_markup=InlineKeyboardMarkup(keyboard))
    else:
        await safe_send_markdown(context.bot, user_id, text, reply_markup=InlineKeyboardMarkup(keyboard))

async def delete_banned_word_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """معالج حذف كلمة محظورة محددة"""
    query = update.callback_query
    if query:
        await query.answer()
    
    user_id = update.effective_user.id
    data_parts = query.data.split(":") if query else []
    
    if len(data_parts) < 3:
        if query:
            await query.edit_message_text("❌ بيانات غير صالحة")
        return
    
    chat_id = int(data_parts[1])
    word = data_parts[2]
    
    if not await is_authorized_in_group(context.bot, chat_id, user_id):
        if query:
            await query.answer(get_text(user_id, 'admin_only'), show_alert=True)
        else:
            await update.message.reply_text(get_text(user_id, 'admin_only'))
        return
    
    success = await db_remove_banned_word(word, chat_id)
    
    if success:
        await query.answer(f"✅ تم حذف '{word}'", show_alert=True)
        await banned_words_list_callback(update, context)
    else:
        await query.answer(f"❌ فشل حذف '{word}'", show_alert=True)

